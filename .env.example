# ============================================================
# AI-Sentinel - Variables de Entorno
# ============================================================

# OBLIGATORIO: Cambiar en produccion (minimo 32 caracteres aleatorios)
SECRET_KEY=cambia-esto-por-un-string-aleatorio-de-32-chars

# Password del admin (minimo 8 chars, 1 mayuscula, 1 numero, 1 especial)
ADMIN_PASSWORD=Admin@Sentinel2024!

# Origenes permitidos (separados por coma)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Requiere JWT para endpoints de analisis/chat/dashboard cuando sea true
REQUIRE_AUTH_FOR_ANALYSIS=false

# API Keys (opcional - la app funciona sin ellas con capacidades reducidas)

# Threat intelligence: URLs, dominios, IPs y archivos
VIRUSTOTAL_API_KEY=
URLSCAN_API_KEY=
ABUSEIPDB_API_KEY=

# IA: chat, analisis de mensajes e imagenes
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini

# Login con Google/Gmail
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
FRONTEND_URL=http://localhost:3000

# Verificador de noticias/desinformacion
GOOGLE_FACT_CHECK_API_KEY=

# Telefono: spam/fraude/reputacion
NUMVERIFY_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_LOOKUP_FROM_COUNTRY=US

# Modo debug (false en produccion)
DEBUG=true
